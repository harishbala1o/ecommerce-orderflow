{
  "realm": "ecommerce-orderflow",
  "enabled": true,
  "registrationAllowed": false,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 7200,
  "roles": {
    "realm": [
      { "name": "customer", "description": "Places and cancels own pending orders" },
      { "name": "ops", "description": "Advances orders through fulfillment" },
      { "name": "admin", "description": "Full visibility and overrides" }
    ]
  },
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "ada",
      "email": "admin@ecommerce-orderflow.dev",
      "firstName": "Ada",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "demo1234", "temporary": false }],
      "realmRoles": ["admin"],
      "attributes": { "hasura_default_role": ["admin"] }
    },
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "username": "otto",
      "email": "ops@ecommerce-orderflow.dev",
      "firstName": "Otto",
      "lastName": "Ops",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "demo1234", "temporary": false }],
      "realmRoles": ["ops"],
      "attributes": { "hasura_default_role": ["ops"] }
    },
    {
      "id": "33333333-3333-3333-3333-333333333333",
      "username": "cara",
      "email": "customer@ecommerce-orderflow.dev",
      "firstName": "Cara",
      "lastName": "Customer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "demo1234", "temporary": false }],
      "realmRoles": ["customer"],
      "attributes": { "hasura_default_role": ["customer"] }
    }
  ],
  "clients": [
    {
      "clientId": "web",
      "name": "Ecommerce OrderFlow Dashboard",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": { "pkce.code.challenge.method": "S256", "post.logout.redirect.uris": "http://localhost:3000/*" },
      "protocolMappers": [
        {
          "name": "hasura-default-role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "hasura_default_role",
            "claim.name": "hasura_default_role",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ]
}
